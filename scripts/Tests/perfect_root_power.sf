#!/usr/bin/ruby

for n in (-100 .. 100) {
    var r = perfect_root(n)
    var k = perfect_power(n)
    assert_eq(r**k, n, "#{r}^#{k} != #{n}")
}

assert_eq(perfect_power(12347**12347 * (2**128 + 1)**2), 1)
assert_eq(perfect_power(12347**12346 * (2**128 + 1)**2), 2)
assert_eq(perfect_power(12347**1236 * (2**128 + 1)**103), 103)
assert_eq(perfect_power(12347**1236 * (2**128 + 1)**206), 206)
assert_eq(perfect_power(12347**1236 * (2**128 + 1)**(5*206)), 206)
assert_eq(perfect_power(12347**12347 * (2**128 + 1)**3), 1)
assert_eq(perfect_power(12347**42 * (2**128 + 1)**42), 42)
assert_eq(perfect_power(12347**142 * (2**128 + 1)**142), 142)
assert_eq(perfect_power(12347**142 * (2**128 + 1)**42), 2)

assert_eq(perfect_power(12347**12347), 12347)
assert_eq(perfect_root(12347**12347), 12347)
assert_eq(prime_power(12347**12347), 12347)
assert_eq(prime_root(12347**12347), 12347)

assert_eq(perfect_root(123456**123456), 123456)
assert_eq(perfect_power(123456**123456), 123456)

say "** Test passed!"

# Solve linear congruence
for a in (1..10), b in (1..10), c in (1..10) {

    var x = solve_lcg(a,b,c)

    if (!x.is_nan) {
        assert_eq(a*x % c, b % c)
        assert(is_congruent(a*x, b, c), [a,b,c])
    }
}

do {
    var x = 1234119781273;
    var a = 13123098712397821;
    var b = 151231230981273;
    var c = 4123129387123;
    var d = 1212387123
    var m = (2**32 + 1)

    var r = (a*x**3 + b*x**2 + c*x + d % m)
    var S = solve_cubic_mod(a, b, c, d - r, m)
    assert_eq(S, %n[1464167034, 2788039718, 3252142948])

    assert(S.map{|x|
       (a*x**3 + b*x**2 + c*x + d - r % m)
    }.all { .is_zero })
}

do {
    var x = 123456;
    var a = 32;
    var b = -15;
    var c = -6;
    var d = 43
    var m = (863 * (2**32 + 1) * 43)

    var r = (a*x**3 + b*x**2 + c*x + d % m)
    var S = solve_cubic_mod(a, b, c, d - r, m)

    assert_eq(S, %n[123456, 20893936668460, 24600493445771, 51891795005810, 55598351783121, 68121763253547, 120013558135901, 123720114913212, 128384083210479])

    assert(S.map{|x|
       (a*x**3 + b*x**2 + c*x + d - r % m)
    }.all{.is_zero})
}

do {
    var x = 123456
    var a = 32
    var b = 48
    var c = 262
    var d = 810
    var n = (43**2 * (2**16 + 1))

    var r = (a*x**3 + b*x**2 + c*x + d % n)

    assert_eq(
        solve_cubic_mod(a, b, c, d - r, n),
        %n[123456, 66315826, 99215400]
    )

    assert_eq(
        Poly([a, b, c, d - r]).roots_mod(n),
        %n[123456, 66315826, 99215400]
    )
}


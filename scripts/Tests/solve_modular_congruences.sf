do {
    var x = 123456
    var a = 32
    var b = 48
    var c = 262
    var d = 810
    var e = 33
    var n = 43*(2**16 + 1)

    var r = (Poly([a,b,c,d,e]).eval(x) % n)

    assert_eq(
        Poly([a, b, c, d, e - r]).roots_mod(n),
        [123456, 254530, 802555, 933629]
    )
}

do {
    var x = 123456
    var a = 32
    var b = 48
    var c = 262
    var d = 810
    var e = 33
    var n = (43**3 * (2**16 + 1))

    var r = (Poly([a,b,c,d,e]).eval(x) % n)

    assert_eq(
        Poly([a, b, c, d, e - r]).roots_mod(n),
        [123456, 333337293, 637143096, 970356933]
    )

    assert([123456, 333337293, 637143096, 970356933].map{|x|
         Poly([a, b, c, d, e - r]).eval(x) % n
    }.all{.is_zero})
}


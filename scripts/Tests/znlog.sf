#!/usr/bin/ruby

# Tests for Number `znlog(a, g, n)` (discrete logarithm)

assert_eq(znlog(5678, 5, 10007), 8620)
assert_eq(znlog(232752345212475230211680, 23847293847923847239847098123812075234, 804842536444911030681947), 13)
assert_eq(znlog(15, 2, 1000000000000000000117), 77714890122519843915)

[
 [[5675,5,10000019], 2003974];  # 5675 = 5^2003974 mod 10000019
 [[18478760,5,314138927], 34034873];
 [[553521,459996,557057], 15471];
 [[7443282,4,13524947], 6762454];
 [[32712908945642193,5,71245073933756341], 5945146967010377];
].each_2d {|t, v|
    say "Testing: discrete_log(#{t.join(', ')}) == #{v}"
    assert_eq(znlog(t...), v)
}

assert_eq(
    36.of{|n| znlog(2**n - 5, 3, 2**(n+1)) }.grep.join(' '),
    %n[NaN, 0, NaN, 1, 7, 3, 27, 43, 75, 139, 11, 779, 267, 1291, 3339, 7435, 32011, 48395, 81163, 146699, 277771, 15627, 1588491, 2637067, 539915, 4734219, 13122827, 63454475, 29900043, 231226635, 97008907, 902315275, 365444363, 1439186187, 3586669835, 7881637131].grep.join(' ')
)

assert_eq({ znlog(-1, 3, 3**_ - 2) || 0 }.map(2 .. 30),
          %n[3, 10, 39, 60, 121, 0, 117, 4920, 0, 0, 0, 28322, 0, 1434890, 0, 0, 0, 116226146, 0, 0, 15690529803, 0, 108443565, 66891206007, 0, 0, 0, 0, 0]);

# Basic correctness tests

assert_eq(znlog(1, 2, 7), 0)
assert_eq(znlog(2, 2, 7), 1)
assert_eq(znlog(4, 2, 7), 2)
assert_eq(znlog(1, 3, 7), 0)

assert_eq(znlog(3, 2, 5), 3)  # 2^3 mod 5 = 3
assert_eq(znlog(4, 2, 5), 2)

assert_eq(znlog(2, 4, 7), 2)
assert_eq(znlog(4, 5, 7), 2)
assert_eq(znlog(5, 3, 7), 5)
assert_eq(znlog(130, 85, 177), 15)
assert_eq(znlog(79, 92, 129), 2)
assert_eq(znlog(115, 116, 141), 26)
assert_eq(znlog(67741, 90737, 120309), 146)
assert_eq(znlog(12, 42, 122), 13)
assert_eq(znlog(36, 44, 50), 2)
assert_eq(znlog(34, 170,187), 5)

# Small modulus cycles

assert_eq(znlog(8, 2, 11), 3)
assert_eq(znlog(5, 2, 11), 4)
assert_eq(znlog(9, 3, 11), 2)

# Edge cases

assert_eq(znlog(1, 1, 13), 0)
assert_eq(znlog(1, 5, 13), 0)

# g == a
assert_eq(znlog(7, 7, 19), 1)

# modulus 2
assert_eq(znlog(1, 1, 2), 0)

# Non-prime modulus

assert_eq(znlog(4, 2, 15), 2)   # 2^2 = 4 mod 15
assert_eq(znlog(1, 4, 9), 0)

# Cases where solution may not exist

assert(znlog(3, 4, 7).is_nan)
assert(znlog(3, 2, 4).is_nan)
assert(znlog(6, 4, 8).is_nan)

# Verify correctness by recomputing power

for n in (7,11,13,17) {
    for g in (2..n-1) {
        for k in (0..n-1) {

            var a = powmod(g, k, n)
            var r = znlog(a, g, n)

            assert(!r.is_nan, "znlog(#{a}, #{g}, #{n})")
            assert_eq(powmod(g, r, n), a)
        }
    }
}

# Randomized tests

100.times {
    var n = irand(50000, 200000)
    var g = irand(2, n-1)
    var k = irand(0, 50000)

    var a = powmod(g, k, n)
    var r = znlog(a, g, n)

    assert(!r.is_nan, "znlog(#{a}, #{g}, #{n})")
    assert_eq(powmod(g, r, n), a)
}

# Computationally intensive tests

var p = 1000003
var g = 2
var k = 123456

var a = powmod(g, k, p)

assert_eq(powmod(g, znlog(a, g, p), p), a)

# Larger exponent

var k2 = 654321
var a2 = powmod(g, k2, p)

assert_eq(powmod(g, znlog(a2, g, p), p), a2)

# Large prime modulus stress test

var p2 = 10000019
var g2 = 2
var k3 = 777777

var a3 = powmod(g2, k3, p2)

assert_eq(powmod(g2, znlog(a3, g2, p2), p2), a3)

# Non-coprime tests
assert_eq(discrete_log(36, 44, 50), 2);    # 44^2 = 1936 = 36 (mod 50), gcd(44,50)=2
assert_eq(discrete_log(0,  2,  4),  2);    # 2^2 = 4 = 0 (mod 4)
assert_eq(discrete_log(4,  6,  8),  2);    # 6^2 = 36 = 4 (mod 8)

# Composite modulus, coprime base
assert_eq(discrete_log(130, 85, 177), 15);    # 177 = 3*59, gcd(85,177)=1
assert_eq(discrete_log(100, 52, 209), 10);    # 209 = 11*19, 52^10 = 100 (mod 209)

# Verify no-solution cases still return undef
assert(discrete_log(3, 4, 6).is_nan);    # no solution exists
